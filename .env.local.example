# regulations.gov — optional. Falls back to "DEMO_KEY" if unset
# (rate-limited but functional). Get a free key at https://api.data.gov/signup/
REGULATIONS_GOV_API_KEY=DEMO_KEY

# Clerk (auth) — optional. If unset, the app falls back to localStorage-only
# mode for profiles. Real Save/Commented/Activity require these.
# Get keys at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (database) — optional. If unset, the app falls back to
# localStorage-only mode. Real Save/Commented/Activity require these.
# Create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (LLM) — optional. If unset, the app falls back to template-based
# comment generation and truncated rule abstracts. Real Gemini-drafted
# comments and plain-language summaries require this.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Resend (email) — optional. Required for Phase 2 features: weekly digest,
# closing-soon alerts, final-rule notifications. Without it, send routes
# log a warning and no-op so the cron jobs stay green.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
# The verified sender address (must match a domain you've verified in Resend).
# Defaults to "OpenComment <hello@opencomment.org>" if unset.
RESEND_FROM_EMAIL=

# Public app URL — used to build links in outbound email (e.g. unsubscribe).
# Set to your Vercel deployment URL in production. Defaults to localhost in dev.
NEXT_PUBLIC_APP_URL=

# Cron secret — random string used to authenticate manual cron triggers.
# Vercel Cron requests are auto-authorized via the x-vercel-cron header.
CRON_SECRET=
